{
  "name": "auroradocs-mcp",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "AuroraCloud-first MCP server that exposes AuroraDocs workspace data to Claude Desktop and other AI agents",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/henrikogaard/auroradocs-mcp.git"
  },
  "homepage": "https://github.com/henrikogaard/auroradocs-mcp#readme",
  "bugs": {
    "url": "https://github.com/henrikogaard/auroradocs-mcp/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "bin": {
    "aurora-mcp": "./dist/index.js"
  },
  "scripts": {
    "test": "tsx --test src/*.test.ts",
    "test:live-smoke-contract": "node --test scripts/auroracloudLiveSmoke.test.mjs",
    "test:stdio": "pnpm build && tsx --test test/stdio.integration.test.ts",
    "build": "tsc -p tsconfig.build.json",
    "check": "pnpm test && pnpm test:live-smoke-contract && pnpm test:stdio && node scripts/packageContents.test.mjs",
    "prepack": "pnpm build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "auroracloud-live-smoke": "tsx scripts/auroracloudLiveSmoke.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3"
  }
}
